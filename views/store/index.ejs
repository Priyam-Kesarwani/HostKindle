<%- include('../partials/head') %>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  </head>

  <body
    class="bg-base-100 text-base-content min-h-screen flex flex-col font-sans selection:bg-primary selection:text-white">
    <%- include('../partials/nav') %>

      <!-- Hero Section -->
      <header class="relative overflow-hidden bg-gradient-to-br from-primary/10 via-secondary/5 to-accent/10 py-16 md:py-24 px-4">
        <!-- Animated background elements -->
        <div class="absolute inset-0 overflow-hidden">
          <div class="absolute top-0 left-1/4 w-96 h-96 bg-primary/15 rounded-full blur-3xl animate-blob"></div>
          <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-secondary/15 rounded-full blur-3xl animate-blob" style="animation-delay: 2s;"></div>
          <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-80 h-80 bg-accent/10 rounded-full blur-3xl animate-blob" style="animation-delay: 4s;"></div>
        </div>

        <div class="relative z-10 max-w-7xl mx-auto">
          <!-- Main Hero Heading -->
          <div class="text-center space-y-8 mb-16 animate-fade-in">
            <h1 class="text-5xl md:text-6xl lg:text-7xl font-black text-white leading-tight tracking-tight">
              <span class="block bg-gradient-to-r from-primary via-secondary to-accent bg-clip-text text-transparent animate-pulse">
                Find Your Perfect Stay
              </span>
              <span class="block text-3xl md:text-4xl lg:text-5xl mt-4 text-white/90 font-bold">
                Near You
              </span>
            </h1>
            <p class="text-lg md:text-2xl max-w-4xl mx-auto leading-relaxed font-medium">
              <span class="inline-block px-4 py-2 rounded-full bg-white/10 border border-white/20 backdrop-blur-md shadow-lg shadow-primary/20">
                <span class="bg-gradient-to-r from-pink-400 via-primary to-cyan-300 bg-clip-text text-transparent font-bold tracking-wide">
                  Handpicked stays, unforgettable moments
                </span>
              </span>
              <span class="block mt-4 text-gray-200/95 font-normal">
                discover unique homes and immersive experiences in the destinations you love
              </span>
            </p>
          </div>

          <!-- Filters Section -->
          <div class="bg-white/10 backdrop-blur-2xl border border-white/20 rounded-3xl p-8 shadow-2xl">
            <form id="filter-form" action="/homes" method="GET" class="space-y-8">
              <!-- Clean Horizontal Filter Bar -->
              <div class="filter-horizontal-container flex flex-wrap items-center gap-6 justify-center">
                <!-- Date Pickers Group -->
                <div class="filter-date-group flex items-center gap-4 bg-white/5 backdrop-blur-lg rounded-2xl p-4 border border-white/10">
                  <div class="space-y-1">
                    <label class="block text-xs font-semibold text-gray-300 uppercase tracking-wider">
                      <i class="fas fa-calendar-check mr-1 text-primary"></i>Check-in
                    </label>
                    <input 
                      type="date" 
                      name="startDate" 
                      id="startDate"
                      value="<%= filterDates && filterDates.startDate ? filterDates.startDate : '' %>"
                      class="px-4 py-2.5 bg-neutral-800/60 border border-white/20 rounded-xl text-white text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all"
                    />
                  </div>
                  
                  <div class="text-white/40 text-xl">→</div>
                  
                  <div class="space-y-1">
                    <label class="block text-xs font-semibold text-gray-300 uppercase tracking-wider">
                      <i class="fas fa-calendar-times mr-1 text-secondary"></i>Check-out
                    </label>
                    <input 
                      type="date" 
                      name="endDate" 
                      id="endDate"
                      value="<%= filterDates && filterDates.endDate ? filterDates.endDate : '' %>"
                      class="px-4 py-2.5 bg-neutral-800/60 border border-white/20 rounded-xl text-white text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all"
                    />
                  </div>
                </div>

                <!-- Location Input -->
                <div class="flex items-center gap-3 bg-white/5 backdrop-blur-lg rounded-2xl p-4 border border-white/10">
                  <div class="space-y-1">
                    <label class="block text-xs font-semibold text-gray-300 uppercase tracking-wider">
                      <i class="fas fa-map-pin mr-1 text-accent"></i>Location
                    </label>
                    <div class="flex items-center gap-2">
                      <input
                        type="text"
                        id="locationInput"
                        name="location"
                        value="<%= geoFilter && geoFilter.location ? geoFilter.location : '' %>"
                        placeholder="Enter location"
                        class="px-4 py-2.5 bg-neutral-800/60 border border-white/20 rounded-xl text-white text-sm placeholder-gray-400 focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all"
                      />
                      <button
                        type="button"
                        id="search-location-btn"
                        class="px-3 py-2.5 bg-secondary/20 hover:bg-secondary/30 border border-secondary/30 text-secondary rounded-xl text-sm font-medium transition-all"
                        title="Search location"
                      >
                        <i class="fas fa-magnifying-glass"></i>
                      </button>
                      <button
                        type="button"
                        data-use-location
                        class="px-3 py-2.5 bg-primary/20 hover:bg-primary/30 border border-primary/30 text-primary rounded-xl text-sm font-medium transition-all"
                      >
                        <i class="fas fa-location-crosshairs"></i>
                      </button>
                    </div>
                  </div>
                </div>

                <!-- Radius Slider -->
                <div class="radius-slider-container flex items-center gap-3 bg-white/5 backdrop-blur-lg rounded-2xl p-4 border border-white/10">
                  <div class="space-y-1">
                    <label class="block text-xs font-semibold text-gray-300 uppercase tracking-wider">
                      <i class="fas fa-ruler mr-1 text-info"></i>Radius
                    </label>
                    <div class="flex items-center gap-3">
                      <input 
                        type="range" 
                        name="radiusKm" 
                        id="radiusKm" 
                        min="1" 
                        max="15" 
                        value="<%= geoFilter && geoFilter.radiusKm ? geoFilter.radiusKm : '5' %>"
                        class="w-24 h-2 bg-white/20 rounded-lg appearance-none cursor-pointer accent-primary"
                      />
                      <span id="radiusValue" class="text-sm font-bold text-primary bg-primary/20 px-3 py-1 rounded-lg min-w-fit">
                        <%= geoFilter && geoFilter.radiusKm ? geoFilter.radiusKm : '5' %> km
                      </span>
                    </div>
                  </div>
                </div>

                <!-- Sort Dropdown -->
                <div class="flex items-center gap-3 bg-white/5 backdrop-blur-lg rounded-2xl p-4 border border-white/10">
                  <div class="space-y-1">
                    <label for="sort-select" class="block text-xs font-semibold text-gray-300 uppercase tracking-wider">
                      <i class="fas fa-arrow-down-up mr-1 text-warning"></i>Sort
                    </label>
                    <div class="relative">
                      <select
                        id="sort-select"
                        name="sortBy"
                        class="px-4 py-2.5 bg-neutral-800/60 border border-white/20 rounded-xl text-white text-sm appearance-none cursor-pointer focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all pr-10"
                      >
                        <option value="">All Results</option>
                        <option value="price|asc">Price: Low → High</option>
                        <option value="price|desc">Price: High → Low</option>
                        <option value="rating|desc">Top Rated</option>
                        <option value="distance|asc">Nearest First</option>
                      </select>
                      <i class="fas fa-chevron-down absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none text-xs"></i>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Hidden fields for location -->
              <input type="hidden" name="latitude" id="latitude" value="<%= geoFilter && geoFilter.latitude ? geoFilter.latitude : '' %>" />
              <input type="hidden" name="longitude" id="longitude" value="<%= geoFilter && geoFilter.longitude ? geoFilter.longitude : '' %>" />

              <!-- Map and Location Button Row -->
              <div class="bg-neutral-900/50 border border-white/5 rounded-xl p-4 space-y-3">
                <div class="flex items-center justify-between flex-wrap gap-3">
                  <p class="text-sm text-gray-300">
                    <i class="fas fa-info-circle mr-2 text-accent"></i>
                    Click on the map to set your location and filter homes within 1-15 km
                  </p>
                  <div class="flex items-center gap-2 flex-wrap">
                    <button
                      type="button"
                      id="clear-geo-filter" 
                      class="px-4 py-2 rounded-lg bg-red-500/20 hover:bg-red-500/30 border border-red-500/30 text-red-300 text-sm font-medium transition-all"
                    >
                      <i class="fas fa-times mr-2"></i>Clear Location
                    </button>
                    <button
                      type="button"
                      data-use-location
                      class="px-4 py-2 rounded-lg bg-primary/20 hover:bg-primary/30 border border-primary/30 text-primary text-sm font-medium transition-all"
                    >
                      <i class="fas fa-location-dot mr-2"></i>Use My Location
                    </button>
                  </div>
                </div>
                <div id="filter-map" class="w-full h-64 rounded-lg overflow-hidden shadow-inner"></div>
              </div>

              <!-- Submit Button -->
              <div class="flex gap-3 justify-center md:justify-end pt-2">
                <a href="/homes" class="px-6 py-3 rounded-lg bg-white/5 hover:bg-white/10 border border-white/10 text-white font-semibold transition-all">
                  <i class="fas fa-redo mr-2"></i>Reset
                </a>
                <button 
                  type="submit" 
                  class="px-8 py-3 rounded-lg bg-gradient-to-r from-primary to-secondary hover:from-primary/90 hover:to-secondary/90 text-white font-bold transition-all duration-300 shadow-lg shadow-primary/25 hover:shadow-lg hover:shadow-secondary/25 active:scale-95"
                >
                  <i class="fas fa-search mr-2"></i>Search Stays
                </button>
              </div>
            </form>
          </div>
        </div>
      </header>

      <main class="container mx-auto px-4 pb-20 flex-grow">
        <% if (isSearchResults) { %>
          <div class="text-center mb-12 animate-fade-in">
            <div class="inline-block px-4 py-1 rounded-full bg-white/5 border border-white/10 mb-4">
              <span class="text-sm text-gray-400">Search Results</span>
            </div>
            <h3 class="text-3xl font-bold text-white mb-2">
              "<%= searchQuery %>"
            </h3>
            <p class="text-gray-400">
              Found <span class="text-primary font-bold">
                <%= registeredHomes.length %>
              </span>
              <%= registeredHomes.length===1 ? 'result' : 'results' %>
            </p>
          </div>
          <% } %>

            <% if (registeredHomes.length===0 && isSearchResults) { %>
              <div class="flex flex-col items-center justify-center py-20 animate-fade-in">
                <div class="w-24 h-24 bg-white/5 rounded-full flex items-center justify-center mb-6">
                  <i class="fas fa-search text-4xl text-gray-600"></i>
                </div>
                <h3 class="text-2xl font-semibold text-white mb-2">No Results Found</h3>
                <p class="text-gray-400 mb-8 max-w-md text-center">We couldn't find any matches for your search. Try
                  broadening your keywords or browse our trending homes.</p>
                <a href="/"
                  class="px-6 py-3 rounded-xl bg-white/10 hover:bg-white/20 text-white font-medium transition-colors border border-white/5">
                  Browse All Properties
                </a>
              </div>
              <% } else { %>

                <% if (!isSearchResults) { %>
                  <div class="flex flex-col md:flex-row justify-between items-center mb-8 border-b border-white/5 pb-4">
                    <h2 class="text-2xl font-bold text-white mb-4 md:mb-0">Trending Stays</h2>
                    <p class="text-sm text-gray-400">Use filters above to sort and refine results</p>
                  </div>
                <% } %>

                    <div id="homes-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
                      <% registeredHomes.forEach((home, index)=> { %>
                        <div
                         class="home-card group
                         bg-[#E4ECFF] text-base-content dark:bg-[#1A1A2E]
                         border border-[#C7D2FE] dark:border-white/5
                         rounded-2xl overflow-hidden
                         transition-all duration-500
                         hover:border-primary/40 hover:-translate-y-2
                         hover:shadow-2xl hover:shadow-primary/10
                         cursor-pointer flex flex-col h-full animate-slide-up"
                          data-price="<%= Number(home.price) || 0 %>"
                          data-rating="<%= Number(home.rating) || 0 %>"
                          data-distance="<%= typeof home.distanceKm === 'number' ? home.distanceKm : 999999 %>"
                          onclick="window.location.href='/homes/<%= home._id %>'">
                          <% let photos=[]; if (home.photos && Array.isArray(home.photos) && home.photos.length> 0) {
                            photos = home.photos.filter(p => p && typeof p === 'string' && p.trim() !== '');
                            } else if (home.photo && typeof home.photo === 'string' && home.photo.trim() !== '') {
                            photos = [home.photo];
                            }
                            const locality = home.address && home.address.locality ? home.address.locality : '';
                            const city = home.address && home.address.city ? home.address.city : '';
                            const displayLocation = [locality, city].filter(Boolean).join(', ') || home.location;
                            photos = photos.map(p => (/^https?:\/\//i.test(p) ? p : (p.startsWith('/') ? p : '/' + p)));
                            const mainPhoto = photos.length > 0 ? photos[0] : '/uploads/default.jpg';
                            %>

                            <div class="relative w-full aspect-[4/3] overflow-hidden">
                              <img src="<%= mainPhoto %>" alt="<%= home.houseName %>"
                                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110">
                              <div
                                class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                              </div>

                              <!-- Favourite Button Wrapper -->
                              <div onclick="event.stopPropagation()" class="absolute top-3 right-3 z-20">
                                <%- include('../partials/favourite', { home: home }) %>
                              </div>

                              <div
                                class="absolute bottom-3 left-3 z-10 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center gap-2">
                                <% if (photos.length> 1) { %>
                                  <span
                                    class="bg-black/50 backdrop-blur-md text-white/90 text-xs px-2 py-1 rounded-full border border-white/10">
                                    <i class="fas fa-images mr-1"></i>
                                    <%= photos.length %>
                                  </span>
                                  <% } %>
                              </div>
                            </div>

                            <div class="p-5 flex flex-col flex-grow bg-[#E4ECFF] dark:bg-[#1A1A2E]">
                              <div class="flex justify-between items-start mb-2">
                                <h3
                                  class="text-lg font-bold text-base-content leading-tight group-hover:text-primary transition-colors">
                                  <%= home.houseName %>
                                </h3>
                                <div class="flex items-center bg-base-200 dark:bg-white/5 px-2 py-1 rounded-lg border border-base-200 dark:border-white/5">
                                  <i class="fas fa-star text-yellow-500 text-xs mr-1"></i>
                                  <span class="text-xs font-bold text-base-content">
                                    <%= (home.rating || 0).toFixed(1) %>
                                  </span>
                                </div>
                              </div>

                              <div class="flex items-center text-gray-600 dark:text-gray-400 mb-3 text-sm">
                                <i class="fas fa-map-marker-alt mr-2 text-primary/70"></i>
                                <span class="truncate">
                                  <%= displayLocation %>
                                </span>
                              </div>
                              <% if (geoFilter && geoFilter.latitude && geoFilter.longitude && typeof home.distanceKm === 'number') { %>
                                <div class="mb-3">
                                  <span class="inline-flex items-center px-2.5 py-1 rounded-full bg-primary/15 text-primary text-xs font-semibold">
                                    <i class="fas fa-location-arrow mr-1"></i>
                                    <%= home.distanceKm.toFixed(1) %> km away
                                  </span>
                                </div>
                              <% } %>

                              <p class="text-gray-700 dark:text-gray-500 text-sm line-clamp-2 mb-4 flex-grow">
                                <%= home.description %>
                              </p>

                              <div class="border-t border-base-200 dark:border-white/5 pt-4 mt-auto flex justify-between items-center">
                                <div>
                                  <span class="text-xs text-gray-500 dark:text-gray-400 uppercase tracking-wider">Price</span>
                                  <div class="text-lg font-bold text-base-content">
                                    Rs <%= home.price %> <span class="text-sm text-gray-600 dark:text-gray-500 font-normal">/ month</span>
                                  </div>
                                </div>

                                <% if (isLoggedIn) { %>
                                  <button
                                    class="bg-base-200 hover:bg-primary hover:text-white text-gray-700 dark:text-gray-300 p-2 rounded-lg transition-all duration-300 border border-base-200 dark:border-white/10 group-hover:border-primary/50">
                                    <i class="fas fa-arrow-right"></i>
                                  </button>
                                  <% } else { %>
                                    <div class="text-xs text-gray-500 italic">Login to book</div>
                                    <% } %>
                              </div>
                            </div>
                        </div>
                        <% }) %>
                    </div>
                    <% } %>

                      <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
                      <script>
                        (function () {
                          // Filter form elements
                          const latInput = document.getElementById('latitude');
                          const lngInput = document.getElementById('longitude');
                          const filterForm = document.getElementById('filter-form');
                          const locationInput = document.getElementById('locationInput');
                          const searchLocationBtn = document.getElementById('search-location-btn');
                          const radiusInput = document.getElementById('radiusKm');
                          const radiusValue = document.getElementById('radiusValue');
                          const useLocationBtns = Array.from(document.querySelectorAll('[data-use-location]'));
                          const clearGeoBtn = document.getElementById('clear-geo-filter');
                          const startDateInput = document.getElementById('startDate');
                          const endDateInput = document.getElementById('endDate');
                          const mapEl = document.getElementById('filter-map');
                          const sortSelect = document.getElementById('sort-select');
                          const homesGrid = document.getElementById('homes-grid');
                          const defaultLat = 28.6139;
                          const defaultLng = 77.209;

                          // Enhanced date picker functionality
                          const localToday = new Date(Date.now() - (new Date().getTimezoneOffset() * 60000)).toISOString().split('T')[0];
                          
                          // Calculate maximum date (6 months from today)
                          const maxDate = new Date(localToday);
                          maxDate.setMonth(maxDate.getMonth() + 6);
                          const maxDateStr = maxDate.toISOString().split('T')[0];
                          
                          // Set minimum and maximum dates for both inputs
                          if (startDateInput) {
                            startDateInput.min = localToday;
                            startDateInput.max = maxDateStr;
                            if (!startDateInput.value) startDateInput.value = localToday;
                          }

                          if (endDateInput) {
                            endDateInput.min = localToday;
                            endDateInput.max = maxDateStr;
                            if (!endDateInput.value) {
                              // Set end date to tomorrow by default
                              const tomorrow = new Date(localToday);
                              tomorrow.setDate(tomorrow.getDate() + 1);
                              endDateInput.value = tomorrow.toISOString().split('T')[0];
                            }
                          }

                          // Enhanced end date validation
                          if (startDateInput && endDateInput) {
                            const updateDateValidation = () => {
                              const startDate = new Date(startDateInput.value || localToday);
                              const minEndDate = new Date(startDate);
                              minEndDate.setDate(minEndDate.getDate() + 1); // End date must be at least next day
                              
                              // Calculate end date maximum (6 months from start date or global max, whichever is smaller)
                              const maxEndDate = new Date(startDate);
                              maxEndDate.setMonth(maxEndDate.getMonth() + 6);
                              const finalMaxDate = maxEndDate > maxDate ? maxDate : maxEndDate;
                              
                              endDateInput.min = minEndDate.toISOString().split('T')[0];
                              endDateInput.max = finalMaxDate.toISOString().split('T')[0];
                              
                              // If current end date is invalid, update it
                              if (endDateInput.value && new Date(endDateInput.value) <= startDate) {
                                endDateInput.value = minEndDate.toISOString().split('T')[0];
                              }
                              
                              // If end date exceeds maximum, update it
                              if (endDateInput.value && new Date(endDateInput.value) > finalMaxDate) {
                                endDateInput.value = finalMaxDate.toISOString().split('T')[0];
                              }
                            };
                            
                            startDateInput.addEventListener('change', updateDateValidation);
                            updateDateValidation();
                          }

                          // Radius slider update
                          if (radiusInput && radiusValue) {
                            radiusInput.addEventListener('input', function () {
                              radiusValue.textContent = this.value + ' km';
                            });
                          }

                          // Initialize map
                          if (mapEl && latInput && lngInput) {
                            const initialLat = parseFloat(latInput.value) || defaultLat;
                            const initialLng = parseFloat(lngInput.value) || defaultLng;
                            const map = L.map(mapEl).setView([initialLat, initialLng], 12);
                            
                            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                              maxZoom: 19,
                              attribution: '&copy; OpenStreetMap contributors'
                            }).addTo(map);

                            let marker = null;
                            let circle = null;

                            const updateMapMarker = (lat, lng) => {
                              if (!marker) {
                                marker = L.marker([lat, lng], {
                                  icon: L.icon({
                                    iconUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/images/marker-icon.png',
                                    iconSize: [25, 41],
                                    iconAnchor: [12, 41],
                                    popupAnchor: [1, -34],
                                    shadowUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/images/marker-shadow.png',
                                    shadowSize: [41, 41]
                                  })
                                }).addTo(map);
                              } else {
                                marker.setLatLng([lat, lng]);
                              }

                              const radiusKm = parseInt(radiusInput.value || '5', 10) || 5;
                              if (!circle) {
                                circle = L.circle([lat, lng], {
                                  radius: radiusKm * 1000,
                                  color: 'var(--p)',
                                  fillColor: 'var(--p)',
                                  fillOpacity: 0.2,
                                  weight: 2
                                }).addTo(map);
                              } else {
                                circle.setLatLng([lat, lng]);
                                circle.setRadius(radiusKm * 1000);
                              }

                              latInput.value = lat;
                              lngInput.value = lng;
                            };

                            const geocodeLocation = async (locationText) => {
                              const query = (locationText || '').trim();
                              if (!query) return null;
                              const url = `https://nominatim.openstreetmap.org/search?format=json&limit=1&q=${encodeURIComponent(query)}`;
                              const response = await fetch(url, {
                                headers: { Accept: 'application/json' },
                              });
                              if (!response.ok) throw new Error('Unable to search location right now.');
                              const results = await response.json();
                              if (!Array.isArray(results) || results.length === 0) return null;
                              return {
                                lat: Number.parseFloat(results[0].lat),
                                lng: Number.parseFloat(results[0].lon),
                              };
                            };

                            // Set initial marker if coordinates exist
                            if (latInput.value && lngInput.value) {
                              updateMapMarker(initialLat, initialLng);
                            }

                            // Click on map to set location
                            map.on('click', (e) => {
                              updateMapMarker(e.latlng.lat, e.latlng.lng);
                            });

                            // Update circle when radius changes
                            if (radiusInput) {
                              radiusInput.addEventListener('input', function () {
                                if (circle && latInput.value && lngInput.value) {
                                  const radiusKm = parseInt(this.value, 10) || 5;
                                  circle.setRadius(radiusKm * 1000);
                                }
                              });
                            }

                            // Use current location
                            useLocationBtns.forEach((btn) => {
                              btn.addEventListener('click', function (e) {
                                e.preventDefault();
                                if (!navigator.geolocation) {
                                  alert('Geolocation is not supported by your browser');
                                  return;
                                }
                                navigator.geolocation.getCurrentPosition(
                                  (pos) => {
                                    const lat = pos.coords.latitude;
                                    const lng = pos.coords.longitude;
                                    map.setView([lat, lng], 13);
                                    updateMapMarker(lat, lng);
                                  },
                                  (err) => {
                                    console.error('Geolocation error:', err);
                                    alert('Unable to get your location. Please enable location access.');
                                  }
                                );
                              });
                            });

                            if (searchLocationBtn && locationInput) {
                              searchLocationBtn.addEventListener('click', async function (e) {
                                e.preventDefault();
                                try {
                                  const point = await geocodeLocation(locationInput.value);
                                  if (!point) {
                                    alert('Location not found. Try a more specific place name.');
                                    return;
                                  }
                                  map.setView([point.lat, point.lng], 13);
                                  updateMapMarker(point.lat, point.lng);
                                } catch (error) {
                                  alert(error.message || 'Failed to search location.');
                                }
                              });
                            }

                            if (locationInput) {
                              locationInput.addEventListener('input', function () {
                                latInput.value = '';
                                lngInput.value = '';
                              });
                            }

                            // Clear location
                            if (clearGeoBtn) {
                              clearGeoBtn.addEventListener('click', function (e) {
                                e.preventDefault();
                                latInput.value = '';
                                lngInput.value = '';
                                if (marker) {
                                  map.removeLayer(marker);
                                  marker = null;
                                }
                                if (circle) {
                                  map.removeLayer(circle);
                                  circle = null;
                                }
                                map.setView([defaultLat, defaultLng], 12);
                              });
                            }

                            if (filterForm && locationInput) {
                              filterForm.addEventListener('submit', async function (event) {
                                const hasTypedLocation = !!locationInput.value.trim();
                                const hasCoordinates = !!latInput.value && !!lngInput.value;
                                if (!hasTypedLocation || hasCoordinates) return;
                                event.preventDefault();
                                try {
                                  const point = await geocodeLocation(locationInput.value);
                                  if (!point) {
                                    alert('Location not found. Please refine the location text.');
                                    return;
                                  }
                                  updateMapMarker(point.lat, point.lng);
                                  filterForm.submit();
                                } catch (error) {
                                  alert(error.message || 'Failed to search location.');
                                }
                              });
                            }
                          }

                          // Sorting functionality
                          if (sortSelect && homesGrid) {
                            const sortHomes = (sortValue) => {
                              if (!sortValue) return;
                              
                              const [field, order] = sortValue.split('|');
                              const cards = Array.from(homesGrid.querySelectorAll('.home-card'));
                              
                              cards.sort((a, b) => {
                                const aValue = parseFloat(a.dataset[field]) || 0;
                                const bValue = parseFloat(b.dataset[field]) || 0;
                                return order === 'asc' ? aValue - bValue : bValue - aValue;
                              });
                              
                              cards.forEach(card => homesGrid.appendChild(card));
                            };

                            sortSelect.addEventListener('change', function () {
                              sortHomes(this.value);
                            });

                            // Apply initial sort if set
                            if (sortSelect.value) {
                              sortHomes(sortSelect.value);
                            }
                          }
                        })();
                      </script>
      </main>
      <%- include('../partials/footer') %>
  </body>

  </html>