<%- include('../partials/head') %>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  </head>

  <body class="bg-base-100 text-base-content min-h-screen">
    <%- include('../partials/nav') %>

      <main class="container mx-auto px-4 py-10 max-w-6xl">
        <h2 class="text-3xl md:text-4xl lg:text-5xl text-center mt-1 mb-8 tracking-wide font-bold text-base-content">
          Find Your Perfect Stay Near You
        </h2>

        <div class="flex items-center justify-end mb-4 gap-3 flex-wrap">
          <form action="/homes" method="GET" class="flex items-center gap-2">
            <input type="date" id="startDateFilter" name="startDate" value="<%= filterDates && filterDates.startDate ? filterDates.startDate : '' %>" class="input input-sm input-bordered" />
            <input type="date" id="endDateFilter" name="endDate" value="<%= filterDates && filterDates.endDate ? filterDates.endDate : '' %>" class="input input-sm input-bordered" />
            <input type="hidden" name="latitude" id="latitude" value="<%= geoFilter && geoFilter.latitude ? geoFilter.latitude : '' %>" />
            <input type="hidden" name="longitude" id="longitude" value="<%= geoFilter && geoFilter.longitude ? geoFilter.longitude : '' %>" />
            <label class="text-xs text-gray-500">Radius</label>
            <input type="range" name="radiusKm" id="radiusKm" min="1" max="15" value="<%= geoFilter && geoFilter.radiusKm ? geoFilter.radiusKm : '5' %>" />
            <span id="radiusValue" class="text-xs"><%= geoFilter && geoFilter.radiusKm ? geoFilter.radiusKm : '5' %> km</span>
            <button class="btn btn-sm btn-primary">Apply</button>
            <a href="/homes" class="btn btn-sm btn-ghost">Back</a>
          </form>
          <label for="sort-select" class="text-sm text-gray-300 mr-2">Sort by:</label>
          <select id="sort-select" class="bg-gray-700 text-white rounded-md px-3 py-1 text-sm">
            <option value="price|asc">Price: Low → High</option>
            <option value="price|desc">Price: High → Low</option>
            <option value="rating|desc">Customer rating</option>
            <option value="distance|asc">Nearest distance</option>
          </select>
        </div>

        <div class="mb-5 bg-base-200 border border-base-300 rounded-xl p-3">
          <div class="flex items-center justify-between mb-2">
            <p class="text-sm">Point on map to search within 1-15 km</p>
            <div class="flex items-center gap-2">
              <button id="clear-distance-filter" type="button" class="btn btn-xs btn-ghost">Remove distance</button>
              <button id="use-my-location" type="button" class="btn btn-xs btn-outline">Use my location</button>
            </div>
          </div>
          <div id="search-map" class="w-full h-56 rounded-lg"></div>
        </div>
        <div id="homes-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
          <% registeredHomes.forEach((home, index)=> { %>
            <div role="link" tabindex="0" title="View details"
              class="home-card group bg-[#E4ECFF] text-base-content dark:bg-[#1A1A2E] border border-[#C7D2FE] dark:border-gray-700 rounded-2xl overflow-hidden hover:border-primary/40 transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl hover:shadow-primary/10 cursor-pointer flex flex-col h-full animate-slide-up"
              data-price="<%= Number(home.price) || 0 %>"
              data-rating="<%= Number(home.rating) || 0 %>"
              data-distance="<%= typeof home.distanceKm === 'number' ? home.distanceKm : 999999 %>"
              onclick="if (!event.target.closest('form')) { window.location='/homes/<%= home._id %>'; }"
              onkeydown="if ((event.key === 'Enter' || event.key === ' ') && !event.target.closest('form')) { window.location='/homes/<%= home._id %>'; }">
              <% 
                // Safely get photos array, filtering out any invalid values
                let photos = [];
                if (home.photos && Array.isArray(home.photos) && home.photos.length > 0) {
                  photos = home.photos.filter(p => p && typeof p === 'string' && p.trim() !== '');
                } else if (home.photo && typeof home.photo === 'string' && home.photo.trim() !== '') {
                  photos = [home.photo];
                }
                // Ensure local photo paths start with /; keep Cloudinary URLs as-is
                photos = photos.map(p => (/^https?:\/\//i.test(p) ? p : (p.startsWith('/') ? p : '/' + p)));
                const mainPhoto = photos.length > 0 ? photos[0] : '/uploads/default.jpg';
              %>
                <div class="relative w-full aspect-[4/3] overflow-hidden">
                  <img src="<%= mainPhoto %>" alt="<%= home.houseName %>"
                    class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110">
                  <div
                    class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                  </div>

                  <!-- Favourite Button Wrapper -->
                  <div onclick="event.stopPropagation()" class="absolute top-3 right-3 z-20">
                    <%- include('../partials/favourite', { home: home }) %>
                  </div>
                </div>

                <div class="p-5 flex flex-col flex-grow bg-[#E4ECFF] dark:bg-[#1A1A2E]">
                  <div class="flex justify-between items-start mb-2">
                    <h3
                      class="text-lg font-bold text-base-content leading-tight group-hover:text-primary transition-colors">
                      <%= home.houseName %>
                    </h3>
                    <div class="flex items-center bg-base-200 dark:bg-white/5 px-2 py-1 rounded-lg border border-base-200 dark:border-white/5">
                      <i class="fas fa-star text-yellow-500 text-xs mr-1"></i>
                      <span class="text-xs font-bold text-base-content">
                        <%= (home.rating || 0).toFixed(1) %>
                      </span>
                    </div>
                  </div>

                  <div class="flex items-center text-gray-600 dark:text-gray-400 mb-3 text-sm">
                    <i class="fas fa-map-marker-alt mr-2 text-primary/70"></i>
                    <span class="truncate">
                      <%= home.location %>
                    </span>
                  </div>
                  <% if (geoFilter && geoFilter.latitude && geoFilter.longitude && typeof home.distanceKm === 'number') { %>
                    <div class="mb-3">
                      <span class="inline-flex items-center px-2.5 py-1 rounded-full bg-primary/15 text-primary text-xs font-semibold">
                        <i class="fas fa-location-arrow mr-1"></i>
                        <%= home.distanceKm.toFixed(1) %> km away
                      </span>
                    </div>
                  <% } %>

                  <p class="text-gray-700 dark:text-gray-500 text-sm line-clamp-2 mb-4 flex-grow">
                    <%= home.description %>
                  </p>

                  <div class="border-t border-base-200 dark:border-white/5 pt-4 mt-auto flex justify-between items-center">
                    <div>
                      <span class="text-xs text-gray-500 dark:text-gray-400 uppercase tracking-wider">Price</span>
                      <div class="text-lg font-bold text-base-content">
                        Rs <%= home.price %> <span class="text-sm text-gray-600 dark:text-gray-500 font-normal">/ month</span>
                      </div>
                    </div>

                    <% if (isLoggedIn && user && String(user._id) !==String(home.owner)) { %>
                      <a href="/homes/<%= home._id %>"
                        class="bg-base-200 hover:bg-primary hover:text-white text-gray-700 dark:text-gray-300 p-2 rounded-lg transition-all duration-300 border border-base-200 dark:border-white/10 group-hover:border-primary/50">
                        <i class="fas fa-arrow-right"></i>
                      </a>
                      <% } else { %>
                        <div class="text-xs text-gray-500 italic">Login to book</div>
                        <% } %>
                  </div>
                </div>
            </div>
            <% }) %>
        </div>

        <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
        <script>
          (function () {
            const latInput = document.getElementById('latitude');
            const lngInput = document.getElementById('longitude');
            const radiusInput = document.getElementById('radiusKm');
            const radiusValue = document.getElementById('radiusValue');
            const useMyLocationBtn = document.getElementById('use-my-location');
            const clearDistanceBtn = document.getElementById('clear-distance-filter');
            const startDateFilter = document.getElementById('startDateFilter');
            const endDateFilter = document.getElementById('endDateFilter');
            const mapEl = document.getElementById('search-map');
            const localToday = new Date(Date.now() - (new Date().getTimezoneOffset() * 60000)).toISOString().split('T')[0];

            if (startDateFilter && !startDateFilter.value) startDateFilter.value = localToday;
            if (startDateFilter) startDateFilter.min = localToday;
            if (endDateFilter && startDateFilter && startDateFilter.value) endDateFilter.min = startDateFilter.value;
            if (startDateFilter && endDateFilter) {
              startDateFilter.addEventListener('change', function () {
                endDateFilter.min = startDateFilter.value || localToday;
                if (endDateFilter.value && endDateFilter.value < (startDateFilter.value || localToday)) {
                  endDateFilter.value = startDateFilter.value || localToday;
                }
              });
            }

            if (mapEl && latInput && lngInput) {
              const initialLat = parseFloat(latInput.value) || 28.6139;
              const initialLng = parseFloat(lngInput.value) || 77.209;
              const map = L.map(mapEl).setView([initialLat, initialLng], 12);
              L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 19,
                attribution: '&copy; OpenStreetMap'
              }).addTo(map);

              let marker = null;
              let circle = null;
              const draw = (lat, lng) => {
                if (!marker) marker = L.marker([lat, lng]).addTo(map);
                marker.setLatLng([lat, lng]);
                const r = (parseInt(radiusInput.value || '5', 10) || 5) * 1000;
                if (!circle) circle = L.circle([lat, lng], { radius: r }).addTo(map);
                circle.setLatLng([lat, lng]);
                circle.setRadius(r);
                latInput.value = String(lat);
                lngInput.value = String(lng);
              };
              if (latInput.value && lngInput.value) draw(initialLat, initialLng);
              map.on('click', (e) => draw(e.latlng.lat, e.latlng.lng));

              radiusInput?.addEventListener('input', () => {
                if (radiusValue) radiusValue.textContent = `${radiusInput.value} km`;
                if (circle) circle.setRadius((parseInt(radiusInput.value, 10) || 5) * 1000);
              });

              useMyLocationBtn?.addEventListener('click', () => {
                if (!navigator.geolocation) return;
                navigator.geolocation.getCurrentPosition((pos) => {
                  const lat = pos.coords.latitude;
                  const lng = pos.coords.longitude;
                  map.setView([lat, lng], 13);
                  draw(lat, lng);
                });
              });

              if (clearDistanceBtn) {
                clearDistanceBtn.addEventListener('click', function () {
                  latInput.value = '';
                  lngInput.value = '';
                  window.location.href = '/homes';
                });
              }
            }

            const select = document.getElementById('sort-select');
            const container = document.getElementById('homes-grid');
            if (!select || !container) return;

            function sortHomes(val) {
              const [field, order] = val.split('|');
              const cards = Array.from(container.querySelectorAll('.home-card'));
              cards.sort((a, b) => {
                const av = parseFloat(a.dataset[field]) || 0;
                const bv = parseFloat(b.dataset[field]) || 0;
                return order === 'asc' ? av - bv : bv - av;
              });
              cards.forEach(c => container.appendChild(c));
            }

            select.addEventListener('change', function () {
              sortHomes(this.value);
            });

            // Apply initial sort on page load (use the current select value)
            if (select.value) {
              sortHomes(select.value);
            }
          })();
        </script>
      </main>
  </body>

  </html>