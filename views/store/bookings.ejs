<%- include('../partials/head') %>
  </head>

  <body class="bg-base-100 text-base-content min-h-screen flex flex-col font-sans selection:bg-primary selection:text-white">
    <%- include('../partials/nav') %>

      <main class="container mx-auto px-4 py-12 max-w-7xl flex-grow animate-fade-in">
        <div class="flex items-center justify-between flex-wrap gap-4 mb-10">
          <div>
            <p class="text-sm text-gray-400">Your reservations</p>
            <h1 class="text-3xl md:text-4xl font-sans font-bold text-base-content tracking-tight">My Bookings</h1>
          </div>
          <a href="/homes"
            class="bg-primary text-white px-4 py-2 rounded-xl font-semibold shadow-md shadow-primary/20 hover:shadow-lg hover:shadow-primary/30 transition">
            Find another home
          </a>
        </div>

        <% if (error) { %>
          <div class="alert alert-error mb-6">
            <span><%= error %></span>
          </div>
        <% } %>
        <% if (success) { %>
          <div class="alert alert-success mb-6">
            <span><%= success %></span>
          </div>
        <% } %>

        <% if (!bookings || bookings.length === 0) { %>
          <div class="flex flex-col items-center justify-center py-16 text-center bg-base-200/60 rounded-2xl border border-base-300">
            <div class="w-20 h-20 rounded-full bg-primary/10 text-primary flex items-center justify-center mb-4">
              <i class="fas fa-calendar-plus text-3xl"></i>
            </div>
            <h2 class="text-2xl font-bold text-base-content mb-2">No bookings yet</h2>
            <p class="text-gray-500 mb-6 max-w-md">Book your first stay to see it appear here.</p>
            <a href="/homes" class="btn btn-primary">Browse homes</a>
          </div>
        <% } else { %>
          <% const activeBookings = bookings.filter((b) => b.status === 'confirmed' || b.status === 'pending'); %>
          <% const historyBookings = bookings.filter((b) => b.status === 'cancelled' || b.status === 'completed'); %>

          <section class="mb-12">
            <h2 class="text-xl font-semibold mb-4">Current Bookings</h2>
            <% if (activeBookings.length === 0) { %>
              <p class="text-gray-500">No active bookings.</p>
            <% } else { %>
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <% activeBookings.forEach((b) => { %>
                  <% const home = b.home; %>
                  <div class="card bg-base-200 shadow-xl border border-base-300">
                    <figure class="relative h-40 overflow-hidden">
                      <img src="<%= (home && home.photos && home.photos[0]) ? home.photos[0] : (home && home.photo ? home.photo : '/uploads/default.jpg') %>"
                        alt="<%= home ? home.houseName : 'Home' %>" class="w-full h-full object-cover">
                      <div class="absolute top-2 right-2 badge badge-primary text-xs text-black text-bold uppercase"><%= b.status %></div>
                    </figure>
                    <div class="card-body space-y-2">
                      <h3 class="card-title text-base-content"><%= home ? home.houseName : 'Home removed' %></h3>
                      <p class="text-sm text-gray-500 flex items-center gap-2">
                        <i class="fas fa-map-marker-alt text-primary"></i>
                        <span><%= home ? home.location : 'Unknown location' %></span>
                      </p>
                      <div class="text-sm text-gray-600">
                        <div class="flex items-center gap-2">
                          <i class="fas fa-calendar-alt text-primary"></i>
                          <span><%= new Date(b.startDate).toLocaleDateString() %> - <%= new Date(b.endDate).toLocaleDateString() %></span>
                        </div>
                        <div class="flex items-center gap-2 mt-1">
                          <i class="fas fa-clock text-primary"></i>
                          <span><%= b.months || 1 %> month(s)</span>
                        </div>
                        <div class="flex items-center gap-2 mt-1">
                          <i class="fas fa-wallet text-primary"></i>
                          <span>Paid: Rs <%= b.totalAmount || 0 %></span>
                        </div>
                      </div>

                      <form action="/bookings/<%= b._id %>/modify" method="POST" class="grid grid-cols-2 gap-2 pt-2">
                        <input type="date" name="startDate" class="input input-sm input-bordered" min="<%= new Date().toISOString().split('T')[0] %>" required>
                        <input type="number" name="months" min="1" max="24" value="<%= b.months || 1 %>" class="input input-sm input-bordered" required>
                        <button type="submit" class="btn btn-sm btn-outline btn-primary col-span-2">Modify booking</button>
                      </form>

                      <div class="card-actions justify-between">
                        <a href="/homes/<%= home ? home._id : '' %>" class="btn btn-sm btn-primary">View home</a>
                        <form action="/bookings/<%= b._id %>/cancel" method="POST" onsubmit="return confirm('Cancel this booking?');">
                          <button type="submit" class="btn btn-sm btn-error btn-outline">Cancel</button>
                        </form>
                      </div>
                    </div>
                  </div>
                <% }) %>
              </div>
            <% } %>
          </section>

          <section>
            <h2 class="text-xl font-semibold mb-4">Booking History</h2>
            <% if (historyBookings.length === 0) { %>
              <p class="text-gray-500">No completed or cancelled bookings yet.</p>
            <% } else { %>
              <div class="overflow-x-auto bg-base-200 rounded-2xl border border-base-300">
                <table class="table">
                  <thead>
                    <tr>
                      <th>Property</th>
                      <th>Duration</th>
                      <th>Amount</th>
                      <th>Status</th>
                      <th>Booked On</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% historyBookings.forEach((b) => { %>
                      <tr>
                        <td><%= b.home ? b.home.houseName : 'Home removed' %></td>
                        <td><%= new Date(b.startDate).toLocaleDateString() %> - <%= new Date(b.endDate).toLocaleDateString() %></td>
                        <td>Rs <%= b.totalAmount || 0 %></td>
                        <td class="uppercase"><%= b.status %></td>
                        <td><%= new Date(b.createdAt).toLocaleDateString() %></td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            <% } %>
          </section>
        <% } %>
      </main>
  </body>

  </html>