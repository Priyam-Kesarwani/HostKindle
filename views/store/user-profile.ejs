<%- include('../partials/head') %>
  </head>

  <body class="bg-base-100 text-base-content min-h-screen flex flex-col font-sans selection:bg-primary selection:text-white">
    <%- include('../partials/nav') %>

      <main class="container mx-auto px-4 py-10 max-w-7xl flex-grow">
        <% const isOwnProfile = isLoggedIn && user && String(user._id) === String(profileUser._id); %>
        <section class="bg-base-200/60 border border-base-300 rounded-3xl p-6 md:p-8 mb-8">
          <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6">
            <div class="flex items-start gap-4">
              <div class="w-16 h-16 rounded-full bg-primary/15 text-primary flex items-center justify-center font-bold text-2xl">
                <%= profileUser.firstName ? profileUser.firstName.charAt(0).toUpperCase() : 'U' %>
              </div>
              <div>
                <h1 class="text-2xl md:text-3xl font-bold">
                  <%= profileUser.firstName %> <%= profileUser.lastName || '' %>
                </h1>
                <p class="text-sm text-gray-400 mt-1">
                  <span class="capitalize"><%= profileUser.userType || 'guest' %></span> account
                </p>
                <p class="text-sm md:text-base text-gray-300 mt-2">
                  <i class="fas fa-envelope mr-2 text-primary"></i><%= profileUser.email %>
                </p>
              </div>
            </div>
            <a href="/homes" class="btn btn-outline btn-sm">Back to homes</a>
          </div>
        </section>

        <section class="mb-10">
          <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
            <div class="rounded-2xl border border-base-300 bg-base-200/60 p-4">
              <p class="text-xs uppercase tracking-wider text-gray-500">Total Bookings</p>
              <p class="text-2xl font-bold"><%= bookings.length %></p>
            </div>
            <div class="rounded-2xl border border-base-300 bg-base-200/60 p-4">
              <p class="text-xs uppercase tracking-wider text-gray-500">Active</p>
              <p class="text-2xl font-bold"><%= activeBookings.length %></p>
            </div>
            <div class="rounded-2xl border border-base-300 bg-base-200/60 p-4">
              <p class="text-xs uppercase tracking-wider text-gray-500">Favourites</p>
              <p class="text-2xl font-bold"><%= favouriteHomes.length %></p>
            </div>
            <div class="rounded-2xl border border-base-300 bg-base-200/60 p-4">
              <p class="text-xs uppercase tracking-wider text-gray-500">Total Spent</p>
              <p class="text-2xl font-bold">Rs <%= totalSpent %></p>
            </div>
          </div>
        </section>

        <section class="mb-12">
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-xl md:text-2xl font-semibold">Current Bookings</h2>
            <span class="text-sm text-gray-400"><%= activeBookings.length %> active</span>
          </div>
          <% if (!activeBookings || activeBookings.length === 0) { %>
            <div class="bg-base-200/60 border border-base-300 rounded-2xl p-8 text-center">
              <p class="text-gray-400">No active bookings available.</p>
            </div>
          <% } else { %>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
              <% activeBookings.forEach((booking) => { %>
                <% const home = booking.home; %>
                <div class="card bg-base-200/70 shadow-lg border border-base-300">
                  <figure class="relative h-40 overflow-hidden">
                    <img
                      src="<%= (home && home.photos && home.photos[0]) ? home.photos[0] : (home && home.photo ? home.photo : '/uploads/default.jpg') %>"
                      alt="<%= home ? home.houseName : 'Home' %>"
                      class="w-full h-full object-cover"
                    >
                    <div class="absolute top-2 right-2 badge badge-primary text-xs text-black font-bold uppercase">
                      <%= booking.status %>
                    </div>
                  </figure>
                  <div class="card-body">
                    <h3 class="card-title text-base-content"><%= home ? home.houseName : 'Home removed' %></h3>
                    <p class="text-sm text-gray-500"><i class="fas fa-map-marker-alt text-primary mr-2"></i><%= home ? home.location : 'Unknown location' %></p>
                    <p class="text-sm text-gray-400">
                      <%= new Date(booking.startDate).toLocaleDateString() %> - <%= new Date(booking.endDate).toLocaleDateString() %>
                    </p>
                    <p class="text-sm text-gray-400">Duration: <%= booking.months || 1 %> month(s)</p>
                    <p class="text-sm text-gray-300 font-medium">Amount: Rs <%= booking.totalAmount || 0 %></p>
                    <% if (home) { %>
                      <div class="card-actions justify-end mt-2">
                        <a href="/homes/<%= home._id %>" class="btn btn-sm btn-primary">View Home</a>
                      </div>
                    <% } %>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } %>
        </section>

        <section class="mb-12">
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-xl md:text-2xl font-semibold">Booking History</h2>
            <span class="text-sm text-gray-400"><%= historyBookings.length %> entries</span>
          </div>
          <% if (!historyBookings || historyBookings.length === 0) { %>
            <div class="bg-base-200/60 border border-base-300 rounded-2xl p-8 text-center">
              <p class="text-gray-400">No completed or cancelled bookings yet.</p>
            </div>
          <% } else { %>
            <div class="overflow-x-auto bg-base-200/70 rounded-2xl border border-base-300">
              <table class="w-full min-w-[920px] text-sm md:text-base border-collapse">
                <thead>
                  <tr class="border-b border-base-300">
                    <th class="text-left font-semibold px-4 py-3">Property</th>
                    <th class="text-left font-semibold px-4 py-3">Start Date</th>
                    <th class="text-left font-semibold px-4 py-3">End Date</th>
                    <th class="text-left font-semibold px-4 py-3">Months</th>
                    <th class="text-left font-semibold px-4 py-3">Amount</th>
                    <th class="text-left font-semibold px-4 py-3">Status</th>
                    <th class="text-left font-semibold px-4 py-3">Booked On</th>
                  </tr>
                </thead>
                <tbody>
                  <% historyBookings.forEach((booking) => { %>
                    <tr class="border-b border-base-300/70 last:border-b-0">
                      <td class="whitespace-nowrap px-4 py-3">
                        <% if (booking.home) { %>
                          <a href="/homes/<%= booking.home._id %>" class="text-primary hover:underline">
                            <%= booking.home.houseName %>
                          </a>
                        <% } else { %>
                          Home removed
                        <% } %>
                      </td>
                      <td class="whitespace-nowrap px-4 py-3"><%= new Date(booking.startDate).toLocaleDateString() %></td>
                      <td class="whitespace-nowrap px-4 py-3"><%= new Date(booking.endDate).toLocaleDateString() %></td>
                      <td class="whitespace-nowrap px-4 py-3"><%= booking.months || 1 %></td>
                      <td class="whitespace-nowrap px-4 py-3">Rs <%= booking.totalAmount || 0 %></td>
                      <td class="whitespace-nowrap px-4 py-3">
                        <span class="badge <%= booking.status === 'cancelled' ? 'badge-error' : 'badge-success' %> uppercase">
                          <%= booking.status %>
                        </span>
                      </td>
                      <td class="whitespace-nowrap px-4 py-3"><%= new Date(booking.createdAt).toLocaleDateString() %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>
        </section>

        <section>
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-xl md:text-2xl font-semibold">Favourite Homes</h2>
            <span class="text-sm text-gray-400"><%= favouriteHomes.length %> saved</span>
          </div>

          <% if (!favouriteHomes || favouriteHomes.length === 0) { %>
            <div class="bg-base-200/60 border border-base-300 rounded-2xl p-8 text-center">
              <p class="text-gray-400">No favourite homes saved yet.</p>
            </div>
          <% } else { %>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
              <% favouriteHomes.forEach((home, index) => { %>
                <% let photos = []; %>
                <% if (home.photos && Array.isArray(home.photos) && home.photos.length > 0) { %>
                  <% photos = home.photos.filter((p) => p && typeof p === 'string' && p.trim() !== ''); %>
                <% } else if (home.photo && typeof home.photo === 'string' && home.photo.trim() !== '') { %>
                  <% photos = [home.photo]; %>
                <% } %>
                <% photos = photos.map((p) => (/^https?:\/\//i.test(p) ? p : (p.startsWith('/') ? p : '/' + p))); %>
                <% const mainPhoto = photos.length > 0 ? photos[0] : '/uploads/default.jpg'; %>
                <div
                  class="group bg-neutral-900/50 dark:bg-[#1A1A2E] backdrop-blur-sm border border-white/5 rounded-2xl overflow-hidden hover:border-primary/30 transition-all duration-300 hover:shadow-2xl hover:shadow-primary/5 cursor-pointer flex flex-col h-full animate-slide-up"
                  style="animation-delay: <%= index * 80 %>ms;"
                  onclick="if (!event.target.closest('form') && !event.target.closest('button')) { window.location.href='/homes/<%= home._id %>'; }"
                >
                  <div class="relative w-full aspect-[4/3] overflow-hidden">
                    <img src="<%= mainPhoto %>" alt="<%= home.houseName %>" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent"></div>
                    <div class="absolute bottom-3 left-3 right-3">
                      <h3 class="text-white font-bold leading-tight truncate mb-1"><%= home.houseName %></h3>
                      <p class="text-gray-300 text-xs"><i class="fas fa-map-marker-alt mr-1"></i><%= home.location %></p>
                    </div>
                  </div>
                  <div class="p-4 flex flex-col flex-grow">
                    <div class="grid grid-cols-2 gap-2 text-xs text-gray-400 mb-4">
                      <div class="flex items-center gap-2 bg-white/5 p-2 rounded-lg">
                        <i class="fas fa-rupee-sign text-primary"></i>
                        <span class="text-white font-medium"><%= home.price %></span>/mo
                      </div>
                      <div class="flex items-center gap-2 bg-white/5 p-2 rounded-lg">
                        <i class="fas fa-star text-yellow-500"></i>
                        <span class="text-white font-medium"><%= (home.rating || 0).toFixed(1) %></span>
                      </div>
                    </div>
                    <div class="mt-auto flex gap-2">
                      <a href="/homes/<%= home._id %>" class="btn btn-sm btn-primary flex-1">View</a>
                      <% if (isOwnProfile) { %>
                        <form action="/favourites/delete/<%= home._id %>" method="POST" class="flex-1">
                          <button type="submit" class="btn btn-sm btn-outline btn-error w-full">Remove</button>
                        </form>
                      <% } %>
                    </div>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } %>
        </section>
      </main>

      <%- include('../partials/footer') %>
  </body>

  </html>
