<%- include('../partials/head') %>
  </head>

  <body class="bg-base-100 text-base-content min-h-screen flex flex-col font-sans selection:bg-primary selection:text-white">
    <%- include('../partials/nav') %>

      <!-- Hero / Title Section -->
      <div class="relative py-12 md:py-16 bg-gradient-to-b from-neutral-900/50 to-neutral">
        <div class="absolute inset-0 overflow-hidden pointer-events-none">
          <div class="absolute top-[-50%] left-[-20%] w-[80%] h-[80%] rounded-full bg-primary/10 blur-[120px]"></div>
          <div class="absolute bottom-[-50%] right-[-20%] w-[80%] h-[80%] rounded-full bg-secondary/10 blur-[120px]">
          </div>
        </div>

        <div class="container mx-auto px-4 relative z-10 text-center">
          <h1 class="text-4xl md:text-6xl font-sans font-bold text-white mb-4 animate-fade-in tracking-tight">
            <%= home.houseName %>
          </h1>
          <div class="flex items-center justify-center gap-6 text-gray-400 animate-slide-up"
            style="animation-delay: 200ms;">
            <span class="flex items-center"><i class="fas fa-map-marker-alt text-primary mr-2"></i>
              <%= home.location %>
            </span>
            <span class="flex items-center"><i class="fas fa-star text-yellow-500 mr-2"></i>
              <%= (home.rating || 0).toFixed(1) %> (<%= home.ratingCount || 0 %>)
            </span>
          </div>
        </div>
      </div>

      <main class="container mx-auto px-4 pb-20 max-w-7xl animate-slide-up" style="animation-delay: 400ms;">

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-16">
          <!-- Image Gallery (Left - 2 Cols) -->
          <div class="lg:col-span-2 space-y-4">
            <% let photos=[]; if (home.photos && Array.isArray(home.photos) && home.photos.length> 0) {
              photos = home.photos.filter(p => p && typeof p === 'string' && p.trim() !== '');
              } else if (home.photo && typeof home.photo === 'string' && home.photo.trim() !== '') {
              photos = [home.photo];
              }
              photos = photos.map(p => (/^https?:\/\//i.test(p) ? p : (p.startsWith('/') ? p : '/' + p)));
              const mainPhoto = photos.length > 0 ? photos[0] : '/uploads/default.jpg';
              const limitedPhotos = photos.slice(0, 3);
              %>

              <div class="rounded-3xl overflow-hidden shadow-2xl relative group h-[400px] md:h-[500px]">
                <img id="main-photo" src="<%= mainPhoto %>" alt="<%= home.houseName %>"
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                  onerror="this.src='/uploads/default.jpg'; this.onerror=null;">
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-60">
                </div>

                <div class="absolute bottom-6 left-6 right-6 flex justify-between items-end">
                  <div>
                    <div
                      class="inline-block px-3 py-1 rounded-full bg-black/40 backdrop-blur-md border border-white/10 text-xs text-white mb-2">
                      <%= photos.length %> Photos
                    </div>
                  </div>

                  <!-- Action Buttons overlay on image for mobile/desktop common actions -->
                  <div class="flex gap-3">
                    <div onclick="event.stopPropagation()">
                      <%- include('../partials/favourite', { home: home }) %>
                    </div>
                  </div>
                </div>
              </div>

              <% if (limitedPhotos.length> 1) { %>
                <div class="grid grid-cols-3 sm:grid-cols-4 gap-4">
                  <% limitedPhotos.forEach((photo, index)=> { %>
                    <div
                      class="relative rounded-xl overflow-hidden aspect-square cursor-pointer group border-2 <%= index === 0 ? 'border-primary' : 'border-transparent' %> hover:border-primary transition-all duration-300"
                      onclick="const mainImg = document.getElementById('main-photo'); if(mainImg) { mainImg.src='<%= photo %>'; } const container = this.parentElement; const thumbs = container.querySelectorAll('div.relative'); thumbs.forEach(div => { div.classList.remove('border-primary'); div.classList.add('border-transparent'); }); this.classList.remove('border-transparent'); this.classList.add('border-primary');">
                      <img src="<%= photo %>" alt="Thumbnail"
                        class="w-full h-full object-cover group-hover:opacity-100 opacity-70 transition-opacity duration-300">
                      <% if (index===2 && photos.length> 3) { %>
                        <div class="absolute inset-0 bg-black/60 flex items-center justify-center">
                          <span class="text-white font-bold text-lg">+<%= photos.length - 3 %></span>
                        </div>
                        <% } %>
                    </div>
                    <% }); %>
                </div>
                <% if (photos.length > 3) { %>
                  <div class="mt-4">
                    <a href="/homes/<%= home._id %>/photos"
                      class="btn btn-primary w-full flex items-center justify-center gap-2">
                      See all photos
                      <i class="fas fa-images text-sm"></i>
                    </a>
                  </div>
                <% } %>
                <% } %>
          </div>

          <!-- Info Sidebar (Right - 1 Col) -->
          <div class="lg:col-span-1">
            <div
              class="bg-neutral-900/50 backdrop-blur-xl border border-white/5 rounded-3xl p-8 sticky top-24 shadow-2xl">
              <div class="flex justify-between items-start mb-6 border-b border-white/5 pb-6">
                <div>
                  <p class="text-gray-400 text-sm uppercase tracking-wider mb-1">Price per month</p>
                  <h3 class="text-3xl font-bold text-white">Rs <%= home.price %>
                  </h3>
                </div>
                <div class="flex items-center bg-yellow-500/10 px-3 py-1 rounded-lg border border-yellow-500/20">
                  <i class="fas fa-star text-yellow-500 mr-1.5"></i>
                  <span class="text-yellow-200 font-bold">
                    <%= (home.rating || 0).toFixed(1) %>
                  </span>
                </div>
              </div>

              <div class="space-y-6 mb-8">
                <div class="flex items-center gap-4 text-gray-300">
                  <div class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-primary">
                    <i class="fas fa-couch"></i>
                  </div>
                  <div>
                    <p class="text-xs text-gray-500 uppercase">Furnishing</p>
                    <p class="font-medium">
                      <%= typeof home.furnished==='string' ? home.furnished : (home.furnished ? 'Furnished'
                        : 'Unfurnished' ) %>
                    </p>
                  </div>
                </div>

                <% if (home.bhk) { %>
                  <div class="flex items-center gap-4 text-gray-300">
                    <div class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-secondary">
                      <i class="fas fa-bed"></i>
                    </div>
                    <div>
                      <p class="text-xs text-gray-500 uppercase">Configuration</p>
                      <p class="font-medium">
                        <%= home.bhk %>
                      </p>
                    </div>
                  </div>
                  <% } %>

                    <div class="flex items-center gap-4 text-gray-300">
                      <div class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-accent">
                        <i class="fas fa-user-check"></i>
                      </div>
                      <div>
                        <p class="text-xs text-gray-500 uppercase">Host</p>
                        <p class="font-medium">Verified Host</p>
                        <!-- Could connect to user data if available in details -->
                      </div>
                    </div>
              </div>

              <!-- CTA Buttons -->
              <div class="space-y-3">
                <% if (isLoggedIn && user && String(user._id)===String(home.owner)) { %>
                  <a href="/host/edit-home/<%= home._id %>?editing=true"
                    class="block w-full text-center bg-white/10 hover:bg-white/20 border border-white/5 text-white py-3 rounded-xl font-bold transition-all">
                    Edit Listing
                  </a>
                  <form action="/host/delete-home/<%= home._id %>" method="POST"
                    onsubmit="return confirm('Delete this home permanently?');">
                    <button type="submit"
                      class="block w-full text-center bg-red-500/10 hover:bg-red-500/20 border border-red-500/30 text-red-500 py-3 rounded-xl font-bold transition-all">
                      Delete Listing
                    </button>
                  </form>
                  <% } else if (isLoggedIn) { %>
                    <% const localToday = new Date(Date.now() - (new Date().getTimezoneOffset() * 60000)).toISOString().split('T')[0]; %>
                    <form id="booking-form" class="space-y-3">
                      <div class="grid grid-cols-2 gap-3">
                        <div class="form-control">
                          <label class="label"><span class="label-text text-gray-300">Move-in date</span></label>
                          <input type="date" name="startDate" id="startDate"
                            class="input input-bordered w-full bg-white/5 border-white/10 text-base-content cursor-pointer"
                            min="<%= localToday %>" value="<%= localToday %>" required>
                        </div>
                        <div class="form-control">
                          <label class="label"><span class="label-text text-gray-300">Months</span></label>
                          <input type="number" name="months" id="months"
                            class="input input-bordered w-full bg-white/5 border-white/10 text-white"
                            min="1" max="24" value="1" required>
                        </div>
                      </div>
                      <button type="button" id="check-availability-btn"
                        class="w-full bg-white/10 hover:bg-white/20 text-white py-3 rounded-xl font-semibold border border-white/10">
                        Check Availability
                      </button>
                      <div id="availability-message" class="text-sm rounded-lg p-3 hidden"></div>
                      <div id="amount-message" class="text-sm text-gray-300"></div>
                      <button type="submit" id="book-now-btn"
                        class="w-full bg-gradient-to-r from-primary to-secondary hover:from-primary/90 hover:to-secondary/90 text-white py-4 rounded-xl font-bold shadow-lg shadow-primary/25 transition-all hover:scale-[1.02] active:scale-[0.98] disabled:opacity-60 disabled:cursor-not-allowed"
                        disabled>
                        Book Now & Pay
                        <i class="fas fa-arrow-right"></i>
                      </button>
                    </form>
                  <% } else { %>
                    <a href="/login"
                      class="w-full inline-flex items-center justify-center gap-2 bg-white/10 text-white font-semibold py-3 rounded-2xl transition-all hover:bg-white/20 border border-white/10">
                      Login to book
                      <i class="fas fa-sign-in-alt"></i>
                    </a>
                    <% } %>
              </div>
            </div>
          </div>
        </div>

        <div id="unavailable-similar" class="hidden bg-neutral-900/30 backdrop-blur-md rounded-3xl p-8 border border-white/5 mb-16">
          <h3 class="text-2xl font-bold text-white mb-4">Similar properties you can book</h3>
          <div id="similar-home-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6"></div>
        </div>

        <% if (similarHomes && similarHomes.length > 0) { %>
          <div class="bg-neutral-900/30 backdrop-blur-md rounded-3xl p-8 border border-white/5 mb-16">
            <h3 class="text-2xl font-bold text-white mb-4">You may also like</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
              <% similarHomes.forEach((item) => { 
                const altPhoto = (item.photos && item.photos[0]) ? item.photos[0] : (item.photo || '/uploads/default.jpg');
              %>
                <a href="/homes/<%= item._id %>" class="block rounded-2xl overflow-hidden border border-white/10 hover:border-primary/40 transition-all bg-neutral-800/60">
                  <img src="<%= altPhoto %>" class="h-36 w-full object-cover" alt="<%= item.houseName %>">
                  <div class="p-4">
                    <h4 class="font-semibold text-white truncate"><%= item.houseName %></h4>
                    <p class="text-sm text-gray-400 truncate"><%= item.location %></p>
                    <p class="text-primary font-semibold mt-2">Rs <%= item.price %> / month</p>
                  </div>
                </a>
              <% }) %>
            </div>
          </div>
        <% } %>

        <!-- Description & Features -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-16">
          <div class="lg:col-span-2 space-y-8">
            <div class="bg-neutral-900/30 backdrop-blur-md rounded-3xl p-8 border border-white/5">
              <h2 class="text-2xl font-bold text-white mb-4">About this place</h2>
              <p class="text-gray-400 leading-relaxed text-lg">
                <%= home.description && home.description.trim() !=='' ? home.description : 'No description provided.' %>
              </p>

              <% if (home.keywords && Array.isArray(home.keywords) && home.keywords.length> 0) { %>
                <div class="flex flex-wrap gap-2 mt-6">
                  <% home.keywords.forEach(k=> { %>
                    <span
                      class="inline-flex items-center px-3 py-1.5 rounded-lg bg-white/5 border border-white/10 text-sm text-gray-300">
                      <i class="fas fa-tag mr-2 text-primary/70 text-xs"></i>
                      <%= k %>
                    </span>
                    <% }) %>
                </div>
                <% } %>
            </div>

            <!-- Property Details -->
            <div class="bg-neutral-900/30 backdrop-blur-md rounded-3xl p-8 border border-white/5">
              <h2 class="text-2xl font-bold text-white mb-6">Property Details</h2>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <% if (home.phoneNumber) { %>
                  <div class="flex items-center gap-4 text-gray-300">
                    <div class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-primary">
                      <i class="fas fa-phone"></i>
                    </div>
                    <div>
                      <p class="text-xs text-gray-500 uppercase">Contact</p>
                      <p class="font-medium"><%= home.phoneNumber %></p>
                    </div>
                  </div>
                <% } %>

                <div class="flex items-center gap-4 text-gray-300">
                  <div class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-secondary">
                    <i class="fas fa-building"></i>
                  </div>
                  <div>
                    <p class="text-xs text-gray-500 uppercase">Property Type</p>
                    <p class="font-medium"><%= home.propertyType || 'Apartment' %></p>
                  </div>
                </div>

                <div class="flex items-center gap-4 text-gray-300">
                  <div class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-status">
                    <i class="fas fa-hourglass-half"></i>
                  </div>
                  <div>
                    <p class="text-xs text-gray-500 uppercase">Property Age</p>
                    <p class="font-medium"><%= home.propertyAge || '1' %> years</p>
                  </div>
                </div>

                <div class="flex items-center gap-4 text-gray-300">
                  <div class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-accent">
                    <i class="fas fa-compass"></i>
                  </div>
                  <div>
                    <p class="text-xs text-gray-500 uppercase">Facing Direction</p>
                    <p class="font-medium"><%= home.facingDirection || 'East' %></p>
                  </div>
                </div>

                <div class="flex items-center gap-4 text-gray-300">
                  <div class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-info">
                    <i class="fas fa-layer-group"></i>
                  </div>
                  <div>
                    <p class="text-xs text-gray-500 uppercase">Total Floors</p>
                    <p class="font-medium"><%= home.totalFloors || 1 %></p>
                  </div>
                </div>
              </div>

              <!-- Food & Amenities -->
              <div class="mt-6 pt-6 border-t border-white/5">
                <h3 class="text-lg font-semibold text-white mb-4">Food & Amenities</h3>
                
                <!-- Food Options -->
                <% if (home.foodIncluded) { %>
                  <div class="mb-6">
                    <div class="flex items-center gap-2 mb-3">
                      <div class="w-8 h-8 rounded-full bg-green-500/20 flex items-center justify-center text-green-400">
                        <i class="fas fa-utensils text-sm"></i>
                      </div>
                      <h4 class="text-white font-medium">Food Available</h4>
                    </div>
                    
                    <% if (home.foodType && home.foodType !== 'None') { %>
                      <div class="flex items-center gap-2 text-gray-300 text-sm mb-2">
                        <span class="inline-block px-2 py-1 rounded bg-white/5 text-xs uppercase tracking-wider">Type</span>
                        <span><%= home.foodType %></span>
                      </div>
                    <% } %>
                    
                    <% if (home.mealPlan && home.mealPlan !== 'None') { %>
                      <div class="flex items-center gap-2 text-gray-300 text-sm">
                        <span class="inline-block px-2 py-1 rounded bg-white/5 text-xs uppercase tracking-wider">Meal Plan</span>
                        <span><%= home.mealPlan %></span>
                      </div>
                    <% } %>
                  </div>
                <% } %>
                
                <!-- Amenities Grid -->
                <div class="mb-6">
                  <h4 class="text-white font-medium mb-3">Amenities</h4>
                  <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
                    <% const amenities = [
                      { key: 'wifi', label: 'Wi-Fi', icon: 'fa-wifi' },
                      { key: 'ac', label: 'Air Conditioning', icon: 'fa-snowflake' },
                      { key: 'laundry', label: 'Laundry', icon: 'fa-tshirt' },
                      { key: 'housekeeping', label: 'Housekeeping', icon: 'fa-broom' },
                      { key: 'security', label: 'Security', icon: 'fa-shield-alt' },
                      { key: 'powerBackup', label: 'Power Backup', icon: 'fa-bolt' },
                      { key: 'waterSupply', label: '24/7 Water', icon: 'fa-tint' },
                      { key: 'lift', label: 'Lift', icon: 'fa-elevator' },
                      { key: 'reservedParking', label: 'Reserved Parking', icon: 'fa-parking' },
                      { key: 'coveredParking', label: 'Covered Parking', icon: 'fa-warehouse' },
                      { key: 'openParking', label: 'Open Parking', icon: 'fa-square-parking' },
                      { key: 'twoWheelParking', label: '2W Parking', icon: 'fa-motorcycle' },
                      { key: 'fourWheelParking', label: '4W Parking', icon: 'fa-car-side' }
                    ]; %>
                    
                    <% let hasAmenities = false; %>
                    <% amenities.forEach(amenity => { %>
                      <% if (home[amenity.key]) { %>
                        <% hasAmenities = true; %>
                        <div class="flex items-center gap-2 px-3 py-2 rounded-lg bg-white/5 border border-white/10 text-gray-300 text-sm">
                          <i class="fas <%= amenity.icon %> text-primary"></i>
                          <span><%= amenity.label %></span>
                        </div>
                      <% } %>
                    <% }); %>
                    
                    <% if (!hasAmenities && !home.foodIncluded) { %>
                      <span class="text-gray-400 text-sm col-span-full">No amenities specified</span>
                    <% } %>
                  </div>
                </div>
                
                <!-- Property Features -->
                <div>
                  <h4 class="text-white font-medium mb-3">Property Features</h4>
                  <div class="flex flex-wrap gap-3">
                    <% if (home.keywords && Array.isArray(home.keywords) && home.keywords.length > 0) { %>
                      <% home.keywords.forEach(keyword => { %>
                        <span class="inline-flex items-center px-3 py-1.5 rounded-lg bg-primary/10 border border-primary/20 text-primary text-sm">
                          <i class="fas fa-check mr-2"></i><%= keyword %>
                        </span>
                      <% }); %>
                    <% } else { %>
                      <span class="text-gray-400 text-sm">No features specified</span>
                    <% } %>
                  </div>
                </div>
              </div>
            </div>

            <!-- Rating Section -->
            <div class="bg-neutral-900/30 backdrop-blur-md rounded-3xl p-8 border border-white/5" id="rating">
              <div class="flex items-center justify-between mb-6">
                <h2 class="text-2xl font-bold text-white">Rate this home</h2>
              </div>

              <div
                class="flex flex-col sm:flex-row items-center gap-8 bg-neutral p-6 rounded-2xl border border-white/5">
                <div class="text-center">
                  <div class="text-5xl font-bold text-white mb-2">
                    <%= (home.rating || 0).toFixed(1) %>
                  </div>
                  <div class="flex justify-center text-yellow-500 mb-2">
                    <% for(let i=1; i<=5; i++) { %>
                      <i
                        class="<%= (home.rating || 0) >= i ? 'fas' : ((home.rating || 0) >= i-0.5 ? 'fas fa-star-half-alt' : 'far') %> fa-star"></i>
                      <% } %>
                  </div>
                  <p class="text-sm text-gray-400">
                    <%= home.ratingCount || 0 %> ratings
                  </p>
                </div>

                <div class="h-px sm:h-20 w-full sm:w-px bg-white/10"></div>

                <div class="flex-grow w-full text-center sm:text-left">
                  <% if (isLoggedIn && user && user.userType === 'guest') { %>
                    <p class="text-gray-300 mb-4">Share your experience by rating this property</p>
                    <form action="/homes/<%= home._id %>/rate" method="POST"
                      class="inline-flex flex-col gap-4 bg-neutral-800 rounded-2xl px-6 py-6 border border-white/10" id="rating-form">
                      <input type="hidden" name="value" id="rating-value"
                        value="<%= userRating ? userRating.value : '' %>">
                      <div class="flex flex-wrap items-center gap-3 justify-center sm:justify-start">
                        <% for (let i=1; i <=5; i++) { %>
                          <button type="button"
                            class="rating-star text-3xl focus:outline-none transition-transform hover:scale-125 <%= userRating && userRating.value >= i ? 'text-yellow-400' : 'text-gray-600' %>"
                            data-value="<%= i %>" aria-label="Rate <%= i %> out of 5">★</button>
                        <% } %>
                      </div>
                      <button type="submit" id="rating-submit"
                        class="mt-2 inline-flex items-center justify-center bg-primary text-white px-6 py-3 rounded-xl font-semibold transition-all hover:bg-primary/90 disabled:cursor-not-allowed disabled:opacity-50"
                        <%= userRating && userRating.value ? '' : 'disabled' %>>Submit Rating</button>
                    </form>
                    <% } else if (isLoggedIn && user) { %>
                      <p class="text-gray-400">Only guest accounts can rate homes.</p>
                    <% } else { %>
                      <p class="text-gray-400 mb-2">Login to rate this home</p>
                      <a href="/login" class="text-primary hover:text-white transition-colors font-semibold">Log in
                        now</a>
                      <% } %>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Reviews Section -->
        <div id="reviews" class="bg-neutral-900/30 backdrop-blur-md rounded-3xl p-8 border border-white/5">
          <div class="flex items-center justify-between mb-8">
            <h2 class="text-2xl font-bold text-white">Guest Reviews</h2>
          </div>

          <% if (home.feedbackSummary) { %>
            <div class="bg-gradient-to-r from-primary/10 to-secondary/10 border border-white/5 rounded-2xl p-6 mb-8">
              <div class="flex gap-4">
                <div
                  class="flex-shrink-0 w-10 h-10 rounded-full bg-gradient-to-br from-primary to-secondary flex items-center justify-center">
                  <i class="fas fa-magic text-white"></i>
                </div>
                <div>
                  <h4 class="text-lg font-bold text-white mb-2">AI Summary</h4>
                  <p class="text-gray-300 leading-relaxed">
                    <%= home.feedbackSummary %>
                  </p>
                </div>
              </div>
            </div>
            <% } %>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <!-- Add Review Form -->
                <div class="md:col-span-2 lg:col-span-1">
                  <% if (isLoggedIn && user && user.userType==='guest' ) { %>
                    <div class="bg-neutral p-6 rounded-2xl border border-white/5 h-full">
                      <h4 class="text-lg font-bold text-white mb-4">Write a Review</h4>
                      <form action="/homes/<%= home._id %>/comments" method="POST" class="space-y-4">
                        <textarea name="text" rows="4" maxlength="500"
                          placeholder="How was your stay? Share your thoughts..."
                          class="w-full bg-neutral-900/50 border border-gray-700 rounded-xl p-4 text-white placeholder-gray-500 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors resize-none"
                          required></textarea>
                        <button type="submit"
                          class="bg-white/10 hover:bg-white/20 text-white px-6 py-2.5 rounded-xl font-semibold transition-all border border-white/5 w-full sm:w-auto">
                          Post Review
                        </button>
                      </form>
                    </div>
                    <% } else if (!isLoggedIn) { %>
                      <div
                        class="bg-neutral p-6 rounded-2xl border border-white/5 border-dashed flex flex-col items-center justify-center text-center h-32">
                        <p class="text-gray-400 mb-2">Want to share your experience?</p>
                        <a href="/login" class="text-primary hover:text-white font-semibold">Log in to write a
                          review</a>
                      </div>
                      <% } %>
                </div>

                <!-- Review List -->
                <div class="md:col-span-2 lg:col-span-1 space-y-4 max-h-[600px] overflow-y-auto pr-2 custom-scrollbar">
                  <% if (comments && comments.length> 0) { %>
                    <% comments.forEach(comment=> { %>
                      <div
                        class="bg-neutral p-5 rounded-2xl border border-white/5 hover:border-white/10 transition-colors">
                        <div class="flex items-center justify-between mb-3">
                          <div class="flex items-center gap-3">
                            <div
                              class="w-8 h-8 rounded-full bg-gradient-to-tr from-gray-700 to-gray-600 flex items-center justify-center font-bold text-xs text-white">
                              <%= (comment.user && comment.user.firstName) ? comment.user.firstName.charAt(0) : 'G' %>
                            </div>
                            <div>
                              <h5 class="text-sm font-bold text-white">
                                <% if (comment.user && comment.user._id) { %>
                                  <a href="/users/<%= comment.user._id %>" class="hover:text-primary transition-colors">
                                    <%= comment.user && comment.user.firstName ? comment.user.firstName : 'Guest' %>
                                      <%= comment.user && comment.user.lastName ? comment.user.lastName : '' %>
                                  </a>
                                <% } else { %>
                                  <%= comment.user && comment.user.firstName ? comment.user.firstName : 'Guest' %>
                                    <%= comment.user && comment.user.lastName ? comment.user.lastName : '' %>
                                <% } %>
                              </h5>
                              <p class="text-xs text-gray-500">
                                <%= new Date(comment.createdAt).toLocaleDateString() %>
                              </p>
                            </div>
                          </div>
                          <% if (isLoggedIn && user && user.userType==='guest' && comment.user && String(user._id)===String(comment.user._id)) { %>
                            <div class="flex items-center gap-3">
                              <a href="/homes/<%= home._id %>/comments/<%= comment._id %>/edit"
                                class="text-xs text-gray-300 hover:text-white transition-colors border border-white/10 rounded-full px-3 py-1.5">Edit</a>
                              <form action="/homes/<%= home._id %>/comments/<%= comment._id %>/delete" method="POST"
                                onsubmit="return confirm('Delete this comment?');">
                                <button type="submit"
                                  class="text-xs text-red-400 hover:text-white hover:bg-white/10 transition-colors border border-red-500/20 rounded-full px-3 py-1.5">Delete</button>
                              </form>
                            </div>
                          <% } %>
                        </div>
                        <p class="text-gray-300 text-sm leading-relaxed">
                          <%= comment.text %>
                        </p>
                      </div>
                      <% }); %>
                        <% } else { %>
                          <div class="text-center py-10 text-gray-500">
                            <i class="far fa-comment-dots text-4xl mb-3 opacity-50"></i>
                            <p>No reviews yet. Be the first!</p>
                          </div>
                          <% } %>
                </div>
              </div>
        </div>

      </main>

      <%- include('../partials/footer') %>

        <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
        <script>
          document.addEventListener('DOMContentLoaded', function () {
            const bookingForm = document.getElementById('booking-form');
            const checkBtn = document.getElementById('check-availability-btn');
            const bookBtn = document.getElementById('book-now-btn');
            const startDateInput = document.getElementById('startDate');
            const monthsInput = document.getElementById('months');
            const availabilityMessage = document.getElementById('availability-message');
            const amountMessage = document.getElementById('amount-message');
            const unavailableSimilar = document.getElementById('unavailable-similar');
            const similarGrid = document.getElementById('similar-home-grid');
            const homeId = "<%= home._id %>";
            const monthlyPrice = Number("<%= Number(home.price || 0) %>");
            let isAvailable = false;

            if (startDateInput) {
              startDateInput.addEventListener('focus', function () {
                if (typeof startDateInput.showPicker === 'function') {
                  startDateInput.showPicker();
                }
              });
            }

            function setMessage(text, type) {
              if (!availabilityMessage) return;
              availabilityMessage.classList.remove('hidden', 'bg-green-500/15', 'text-green-300', 'bg-red-500/15', 'text-red-300');
              availabilityMessage.textContent = text;
              if (type === 'success') {
                availabilityMessage.classList.add('bg-green-500/15', 'text-green-300');
              } else {
                availabilityMessage.classList.add('bg-red-500/15', 'text-red-300');
              }
            }

            function renderSimilar(homes) {
              if (!unavailableSimilar || !similarGrid) return;
              if (!homes || homes.length === 0) {
                unavailableSimilar.classList.add('hidden');
                similarGrid.innerHTML = '';
                return;
              }
              similarGrid.innerHTML = homes.map((item) => {
                const photo = (item.photos && item.photos[0]) ? item.photos[0] : (item.photo || '/uploads/default.jpg');
                return `
                  <a href="/homes/${item._id}" class="block rounded-2xl overflow-hidden border border-white/10 hover:border-primary/40 transition-all bg-neutral-800/60">
                    <img src="${photo}" class="h-36 w-full object-cover" alt="${item.houseName}">
                    <div class="p-4">
                      <h4 class="font-semibold text-white truncate">${item.houseName}</h4>
                      <p class="text-sm text-gray-400 truncate">${item.location || ''}</p>
                      <p class="text-primary font-semibold mt-2">Rs ${item.price} / month</p>
                    </div>
                  </a>
                `;
              }).join('');
              unavailableSimilar.classList.remove('hidden');
            }

            async function checkAvailability() {
              if (!startDateInput || !monthsInput) return false;
              const months = parseInt(monthsInput.value, 10) || 1;
              amountMessage.textContent = `Total payable: Rs ${months * monthlyPrice}`;

              const response = await fetch(`/homes/${homeId}/check-availability`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                  startDate: startDateInput.value,
                  months: months
                })
              });
              const data = await response.json();
              if (!response.ok || !data.success) {
                throw new Error(data.message || 'Unable to check availability.');
              }
              isAvailable = !!data.available;
              bookBtn.disabled = !isAvailable;
              if (isAvailable) {
                setMessage('Available for selected duration. You can proceed to payment.', 'success');
                renderSimilar([]);
              } else {
                setMessage(data.message || 'Not available for selected dates.', 'error');
                renderSimilar(data.similarHomes || []);
              }
              return isAvailable;
            }

            if (checkBtn) {
              checkBtn.addEventListener('click', async function () {
                try {
                  await checkAvailability();
                } catch (err) {
                  setMessage(err.message, 'error');
                }
              });
            }

            if (bookingForm) {
              bookingForm.addEventListener('submit', async function (event) {
                event.preventDefault();
                try {
                  if (!isAvailable) {
                    const ok = await checkAvailability();
                    if (!ok) return;
                  }

                  const months = parseInt(monthsInput.value, 10) || 1;
                  const orderResp = await fetch(`/homes/${homeId}/payment/order`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                      startDate: startDateInput.value,
                      months: months
                    })
                  });
                  const orderData = await orderResp.json();
                  if (!orderResp.ok || !orderData.success) {
                    throw new Error(orderData.message || 'Unable to create payment order.');
                  }

                  const options = {
                    key: orderData.key,
                    amount: orderData.order.amount,
                    currency: orderData.order.currency,
                    name: orderData.home.name,
                    description: `Booking for ${orderData.bookingDraft.months} month(s)`,
                    order_id: orderData.order.id,
                    handler: async function (paymentResponse) {
                      const verifyResp = await fetch(`/homes/${homeId}/payment/verify`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                          razorpay_order_id: paymentResponse.razorpay_order_id,
                          razorpay_payment_id: paymentResponse.razorpay_payment_id,
                          razorpay_signature: paymentResponse.razorpay_signature,
                          startDate: startDateInput.value,
                          months: months,
                          totalAmount: orderData.bookingDraft.totalAmount
                        })
                      });
                      const verifyData = await verifyResp.json();
                      if (!verifyResp.ok || !verifyData.success) {
                        throw new Error(verifyData.message || 'Payment verification failed.');
                      }
                      window.location.href = verifyData.redirectUrl || '/bookings';
                    },
                    prefill: {
                      name: orderData.user.name,
                      email: orderData.user.email
                    },
                    theme: { color: '#6366f1' }
                  };

                  const rzp = new Razorpay(options);
                  rzp.open();
                } catch (err) {
                  setMessage(err.message || 'Booking failed. Please try again.', 'error');
                }
              });
            }

            const form = document.getElementById('rating-form');
            if (form) {
              const hiddenInput = document.getElementById('rating-value');
              const stars = form.querySelectorAll('.rating-star');

              function updateStars(selectedValue) {
                stars.forEach(function (star) {
                  const value = parseInt(star.getAttribute('data-value'), 10);
                  if (value <= selectedValue) {
                    star.classList.add('text-yellow-400');
                    star.classList.remove('text-gray-600');
                  } else {
                    star.classList.add('text-gray-600');
                    star.classList.remove('text-yellow-400');
                  }
                });
              }

              // Initialize from server value
              if (hiddenInput && hiddenInput.value) {
                updateStars(parseInt(hiddenInput.value));
              }

              const submitBtn = document.getElementById('rating-submit');

              function updateSubmitState() {
                if (!submitBtn || !hiddenInput) return;
                submitBtn.disabled = !hiddenInput.value;
              }

              // Initialize from server value
              if (hiddenInput && hiddenInput.value) {
                updateStars(parseInt(hiddenInput.value));
              }
              updateSubmitState();

              stars.forEach(function (star) {
                star.addEventListener('click', function () {
                  const value = parseInt(star.getAttribute('data-value'), 10);
                  if (isNaN(value)) return;
                  if (hiddenInput) hiddenInput.value = value;
                  updateStars(value);
                  updateSubmitState();
                });
              });

              if (form) {
                form.addEventListener('submit', function (event) {
                  if (!hiddenInput || !hiddenInput.value) {
                    event.preventDefault();
                    return;
                  }
                });
              }
            }
          });
        </script>
  </body>

  </html>